# API
PORT=3001

# PostgreSQL local uniquement. Remplacer ces valeurs dans .env.
POSTGRES_DB=pgys
POSTGRES_USER=pgys
POSTGRES_PASSWORD=change-me-local-only
DATABASE_URL=postgresql://pgys:change-me-local-only@localhost:5432/pgys?schema=public

# Authentification. Générer deux secrets aléatoires distincts en environnement réel.
JWT_ACCESS_SECRET=replace-with-a-random-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-random-refresh-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
