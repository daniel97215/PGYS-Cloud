generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  CLOSING
  CLOSED
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REVOKED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum ServiceType {
  CLOUD
  HOSTING
  BACKUP
  APP
  MAINTENANCE
  MAIL
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum ServiceStatus {
  REQUESTED
  PROVISIONING
  ACTIVE
  DEGRADED
  SUSPENDED
  TERMINATING
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  OVERDUE
  VOID
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  MEMBER_INVITED
  MEMBER_REVOKED
  ROLE_CHANGED
  SERVICE_CONFIG_CHANGED
}

model Workspace {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String
  displayName          String                @db.VarChar(120)
  legalName            String?
  siret                String?               @db.VarChar(14)
  siren                String?               @db.VarChar(9)
  vatNumber            String?               @db.VarChar(32)
  addressLine1         String?
  addressLine2         String?
  postalCode           String?               @db.VarChar(20)
  city                 String?
  country              String?               @db.VarChar(80)
  slug                 String                @unique
  status               WorkspaceStatus       @default(DRAFT)
  billingEmail         String?
  phone                String?
  website              String?               @db.VarChar(2048)
  logoUrl              String?               @db.VarChar(2048)
  locale               String                @default("fr-FR")
  language             String?               @db.VarChar(2)
  timezone             String                @default("Europe/Paris")
  currency             String?               @db.VarChar(3)
  activity             String?
  companySize          String?               @db.VarChar(80)
  members              Member[]
  subscriptions        Subscription[]
  services             Service[]
  workspaceServices    WorkspaceService[]
  products             Product[]
  productCategories    ProductCategory[]
  businessPartnerRoles BusinessPartnerRole[]
  businessPartnerTags  BusinessPartnerTag[]
  businessPartnerCategories BusinessPartnerCategory[]
  businessPartners     BusinessPartner[]
  invoices             Invoice[]
  tickets              Ticket[]
  activities           Activity[]
  auditLogs            AuditLog[]
  settings             WorkspaceSettings?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  closedAt             DateTime?

  @@index([name])
  @@index([status])
}

model WorkspaceSettings {
  id                    String    @id @default(uuid()) @db.Uuid
  workspaceId           String    @unique @db.Uuid
  language              String    @default("fr") @db.VarChar(2)
  timezone              String    @default("Europe/Paris") @db.VarChar(80)
  currency              String    @default("EUR") @db.VarChar(3)
  requireMfa            Boolean   @default(false)
  sessionTimeoutMinutes Int       @default(480)
  dateFormat            String    @default("dd/MM/yyyy") @db.VarChar(32)
  timeFormat            String    @default("HH:mm") @db.VarChar(32)
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String?
  status       UserStatus @default(INVITED)
  firstName    String
  lastName     String
  lastLoginAt  DateTime?
  members      Member[]
  sessions     Session[]
  tickets      Ticket[]
  activities   Activity[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([lastName, firstName])
  @@index([status])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?   @db.VarChar(64)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastSeenAt       DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Member {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @db.Uuid
  userId      String       @db.Uuid
  role        MemberRole   @default(MEMBER)
  status      MemberStatus @default(INVITED)
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  user        User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  invitedAt   DateTime     @default(now())
  joinedAt    DateTime?
  revokedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId, status])
  @@index([userId])
}

model Product {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  code        String
  name        String
  description String?
  type        ProductType
  status      ProductStatus @default(ACTIVE)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([code])
  @@index([name])
  @@index([type])
  @@index([status])
}

model ProductCategory {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  code        String
  name        String
  description String?
  isActive    Boolean   @default(true)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([code])
  @@index([name])
  @@index([isActive])
}

model ServiceDefinition {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique
  name         String
  description  String?
  version      String
  isActive     Boolean  @default(true)
  configSchema Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ServiceCatalogItem {
  id                  String         @id @default(uuid()) @db.Uuid
  key                 String         @unique
  name                String
  description         String?
  category            String?
  version             String         @default("1.0.0")
  status              String         @default("draft")
  configurationSchema Json?
  icon                String?
  visibility          String         @default("private")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  offerServices       OfferService[]

  @@index([status])
  @@index([category])
  @@index([visibility])
}

model Offer {
  id            String         @id @default(uuid()) @db.Uuid
  key           String         @unique
  name          String
  description   String?
  status        String         @default("draft")
  visibility    String         @default("public")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  offerFeatures OfferFeature[]
  offerServices OfferService[]
  prices        Price[]
  subscriptions Subscription[]
}

model OfferService {
  id                   String             @id @default(uuid()) @db.Uuid
  offerId              String             @db.Uuid
  serviceCatalogItemId String             @db.Uuid
  configuration        Json?
  createdAt            DateTime           @default(now())
  offer                Offer              @relation(fields: [offerId], references: [id], onDelete: Cascade)
  serviceCatalogItem   ServiceCatalogItem @relation(fields: [serviceCatalogItemId], references: [id], onDelete: Cascade)

  @@unique([offerId, serviceCatalogItemId])
}

model Feature {
  id            String         @id @default(uuid()) @db.Uuid
  key           String         @unique
  name          String
  description   String?
  category      String?
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  offerFeatures OfferFeature[]

  @@index([category])
  @@index([status])
}

model OfferFeature {
  id        String   @id @default(uuid()) @db.Uuid
  offerId   String   @db.Uuid
  featureId String   @db.Uuid
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  offer     Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([offerId, featureId])
  @@index([offerId])
  @@index([featureId])
}

model Price {
  id            String         @id @default(uuid()) @db.Uuid
  offerId       String         @db.Uuid
  currency      String         @default("EUR")
  amount        Decimal        @db.Decimal(12, 2)
  billingPeriod String
  validFrom     DateTime
  validTo       DateTime?
  status        String         @default("active")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  offer         Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([offerId])
  @@index([status])
  @@index([currency])
}

model WorkspaceService {
  id            String    @id @default(uuid()) @db.Uuid
  workspaceId   String    @db.Uuid
  serviceKey    String
  status        String
  configuration Json?
  activatedAt   DateTime?
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, serviceKey])
  @@index([workspaceId])
  @@index([serviceKey])
}

model Subscription {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  offerId     String    @db.Uuid
  priceId     String?   @db.Uuid
  status      String    @default("pending")
  startedAt   DateTime
  endsAt      DateTime?
  cancelledAt DateTime?
  renewalDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  offer       Offer     @relation(fields: [offerId], references: [id])
  price       Price?    @relation(fields: [priceId], references: [id])

  @@index([workspaceId])
  @@index([status])
  @@index([renewalDate])
}

model BusinessPartner {
  id              String                          @id @default(uuid()) @db.Uuid
  workspaceId     String                          @db.Uuid
  code            String
  type            String
  name            String
  legalName       String?
  status          String                          @default("active")
  notes           String?
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  workspace       Workspace                       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  addresses       BusinessPartnerAddress[]
  contacts        BusinessPartnerContact[]
  documents       BusinessPartnerDocument[]
  partnerNotes    BusinessPartnerNote[]
  roleAssignments BusinessPartnerRoleAssignment[]
  tagAssignments  BusinessPartnerTagAssignment[]
  timelineEntries BusinessPartnerTimelineEntry[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([status])
  @@index([name])
}

model BusinessPartnerAddress {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @db.Uuid
  businessPartnerId   String   @db.Uuid
  label        String
  addressLine1 String
  addressLine2 String?
  postalCode   String
  city         String
  state        String?
  countryCode  String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  businessPartner BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([businessPartnerId])
  @@index([postalCode])
  @@index([city])
  @@index([countryCode])
}

model BusinessPartnerContact {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  businessPartnerId  String   @db.Uuid
  firstName   String
  lastName    String
  jobTitle    String?
  email       String?
  phone       String?
  mobile      String?
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  businessPartner BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([businessPartnerId])
  @@index([email])
  @@index([lastName])
  @@index([isActive])
}

model BusinessPartnerNote {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  businessPartnerId  String   @db.Uuid
  title       String?
  content     String
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  businessPartner BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([businessPartnerId])
  @@index([createdAt])
}

model BusinessPartnerDocument {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @db.Uuid
  businessPartnerId   String   @db.Uuid
  name         String
  documentType String
  fileName     String
  mimeType     String
  fileSize     Int
  storageKey   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  businessPartner BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([businessPartnerId])
  @@index([documentType])
  @@index([createdAt])
}

model BusinessPartnerTag {
  id          String                         @id @default(uuid()) @db.Uuid
  workspaceId String                         @db.Uuid
  code        String
  name        String
  color       String?
  isSystem    Boolean                        @default(false)
  isActive    Boolean                        @default(true)
  createdAt   DateTime                       @default(now())
  updatedAt   DateTime                       @updatedAt
  workspace   Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments BusinessPartnerTagAssignment[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([code])
  @@index([isActive])
}

model BusinessPartnerTagAssignment {
  id                   String             @id @default(uuid()) @db.Uuid
  workspaceId          String             @db.Uuid
  businessPartnerId           String             @db.Uuid
  businessPartnerTagId String             @db.Uuid
  assignedAt           DateTime           @default(now())
  businessPartner      BusinessPartner           @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)
  businessPartnerTag   BusinessPartnerTag @relation(fields: [businessPartnerTagId], references: [id], onDelete: Cascade)

  @@unique([businessPartnerId, businessPartnerTagId])
  @@index([workspaceId])
  @@index([businessPartnerId])
  @@index([businessPartnerTagId])
}

model BusinessPartnerTimelineEntry {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @db.Uuid
  businessPartnerId   String   @db.Uuid
  eventType    String
  title        String
  description  String?
  sourceModule String
  sourceId     String?
  metadata     Json?
  occurredAt   DateTime
  createdAt    DateTime @default(now())
  businessPartner BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([businessPartnerId])
  @@index([eventType])
  @@index([sourceModule])
  @@index([occurredAt])
}

model BusinessPartnerCategory {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  code        String
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([name])
  @@index([isActive])
}

model BusinessPartnerRole {
  id          String                          @id @default(uuid()) @db.Uuid
  workspaceId String                          @db.Uuid
  code        String
  name        String
  description String?
  isSystem    Boolean                         @default(false)
  isActive    Boolean                         @default(true)
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @updatedAt
  workspace   Workspace                       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments BusinessPartnerRoleAssignment[]

  @@unique([workspaceId, code])
  @@index([workspaceId])
  @@index([code])
  @@index([isActive])
}

model BusinessPartnerRoleAssignment {
  id                    String              @id @default(uuid()) @db.Uuid
  workspaceId           String              @db.Uuid
  businessPartnerId            String              @db.Uuid
  businessPartnerRoleId String              @db.Uuid
  assignedAt            DateTime            @default(now())
  assignedBy            String?
  businessPartner       BusinessPartner            @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)
  businessPartnerRole   BusinessPartnerRole @relation(fields: [businessPartnerRoleId], references: [id], onDelete: Cascade)

  @@unique([businessPartnerId, businessPartnerRoleId])
  @@index([workspaceId])
  @@index([businessPartnerId])
  @@index([businessPartnerRoleId])
}

model ProvisioningJob {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @db.Uuid
  subscriptionId String    @db.Uuid
  status         String
  operation      String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  error          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([workspaceId])
  @@index([subscriptionId])
  @@index([status])
}

model Service {
  id             String           @id @default(uuid()) @db.Uuid
  workspaceId    String           @db.Uuid
  subscriptionId String?          @unique @db.Uuid
  name           String
  type           ServiceType
  status         ServiceStatus    @default(REQUESTED)
  version        Int              @default(1)
  /// Configuration non secrète, validée par l'API avant écriture.
  config         Json
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  accounts       ServiceAccount[]
  tickets        Ticket[]
  activities     Activity[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  terminatedAt   DateTime?

  @@index([workspaceId, status])
  @@index([type, status])
}

model ServiceAccount {
  id          String   @id @default(uuid()) @db.Uuid
  serviceId   String   @db.Uuid
  email       String   @unique
  displayName String?
  externalId  String?
  isActive    Boolean  @default(true)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([serviceId, isActive])
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  workspaceId    String        @db.Uuid
  subscriptionId String?       @db.Uuid
  number         String        @unique
  status         InvoiceStatus @default(DRAFT)
  totalAmount    Decimal       @db.Decimal(12, 2)
  currency       String        @default("EUR") @db.VarChar(3)
  billingDetails Json
  issuedAt       DateTime      @default(now())
  dueAt          DateTime
  paidAt         DateTime?
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([workspaceId, status])
  @@index([subscriptionId])
  @@index([status, dueAt])
}

model Ticket {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @db.Uuid
  serviceId   String?        @db.Uuid
  createdById String?        @db.Uuid
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(NORMAL)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  service     Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdBy   User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  activities  Activity[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  resolvedAt  DateTime?

  @@index([workspaceId, status])
  @@index([serviceId])
  @@index([createdById])
  @@index([status, priority])
}

model Activity {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String?   @db.Uuid
  serviceId   String?   @db.Uuid
  ticketId    String?   @db.Uuid
  type        String
  message     String
  metadata    Json?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  service     Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  ticket      Ticket?   @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([userId])
  @@index([serviceId])
  @@index([ticketId])
}

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @db.Uuid
  actorId     String?     @db.Uuid
  action      AuditAction
  targetType  String
  targetId    String?
  metadata    Json?
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  actor       User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([workspaceId, createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}
